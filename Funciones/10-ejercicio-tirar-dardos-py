# Importamos la librería random, que nos permite generar números aleatorios
import random


# Definimos una función llamada tirar_dados
# "veces" es la cantidad de lanzamientos que queremos simular
def tirar_dados(veces):

    # Creamos un diccionario llamado "frecuencias"
    # Este diccionario tendrá como claves los números del 1 al 6 (caras del dado)
    # y como valor empezará en 0 (aún no ha salido ningún número)
    frecuencias = {i: 0 for i in range(1, 7)}

    # Validamos que el número de lanzamientos sea mayor a 0
    if veces <= 0:
        return "Error: El número de lanzamientos debe ser mayor a 0."

    # Repetimos el proceso tantas veces como indique "veces"
    for _ in range(veces):

        # Generamos un número aleatorio entre 1 y 6 (simula lanzar un dado)
        resultado = random.randint(1, 6)

        # Sumamos 1 al contador de ese resultado en el diccionario
        frecuencias[resultado] += 1

    # Recorremos el diccionario para mostrar resultados
    for cara, frecuencia in frecuencias.items():

        # Calculamos el porcentaje de veces que salió cada número
        porcentaje = (frecuencia / veces) * 100

        # Mostramos el resultado con 2 decimales
        print(
            f"Porcentaje de veces que salió la cara {cara}: {porcentaje:.2f}%")


# Ejemplo de uso de la función:
tirar_dados(10)
